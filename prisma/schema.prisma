generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                  Int    @id @default(autoincrement())
  provider            String
  accountId           String @unique
  accountIdToken      String @unique
  accountRefreshToken String @unique
  userId              Int
  user                User   @relation(fields: [userId], references: [id])
}

model User {
  id               Int                @id @default(autoincrement())
  name             String
  email            String             @unique
  Account          Account[]
  BusinessProfile  BusinessProfile[]
  CustomCategories CustomCategories[]
  Votes            Votes[]
}

model BusinessProfile {
  id               Int      @id @default(autoincrement())
  profileId        Int      @unique
  name             String   @unique
  pfp              String   @unique
  category         String
  address          String
  city             String
  country          String
  customCategories String[]
  phone            String
  website          String
  addedById        Int
  user             User     @relation(fields: [addedById], references: [id])
  votes            Votes[]
}

model CustomCategories {
  id        Int    @id @default(autoincrement())
  name      String @unique
  createdAt String
  aurtherId Int
  user      User   @relation(fields: [aurtherId], references: [id])
}

model Votes {
  id        Int      @id @default(autoincrement())
  voteType  VoteType
  votedById Int

  user              User            @relation(fields: [votedById], references: [id])
  businessProfileId Int
  BusinessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id])

  @@unique([votedById, businessProfileId])
}

enum VoteType {
  UP
  DOWN
}
