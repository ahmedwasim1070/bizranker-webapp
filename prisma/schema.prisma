generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int                @id @default(autoincrement())
  userId           String             @unique
  email            String             @unique
  name             String
  BusinessProfile  BusinessProfile[]
  CustomCategories CustomCategories[]
  Votes            Votes[]
}

model BusinessProfile {
  id               Int                             @id @default(autoincrement())
  profileId        String                          @unique
  name             String                          @unique
  pfp              String                          @unique
  category         String
  address          String
  city             String
  country          String
  phone            String
  website          String
  mapsUrl          String                          @unique
  reviewValue      Float
  reviewAmount     Int
  addedById        Int
  user             User                            @relation(fields: [addedById], references: [id])
  customCategories BusinessProfileCustomCategory[]
}

model CustomCategories {
  id               Int                             @id @default(autoincrement())
  name             String                          @unique
  createdAt        String
  authorId         Int
  author           User                            @relation(fields: [authorId], references: [id])
  businessProfiles BusinessProfileCustomCategory[]
}

model BusinessProfileCustomCategory {
  id                Int              @id @default(autoincrement())
  businessProfileId Int
  customCategoryId  Int
  businessProfile   BusinessProfile  @relation(fields: [businessProfileId], references: [id])
  customCategory    CustomCategories @relation(fields: [customCategoryId], references: [id])

  upVotes   Int @default(0)
  downVotes Int @default(0)

  votes Votes[]

  @@unique([businessProfileId, customCategoryId])
}

model Votes {
  id        Int      @id @default(autoincrement())
  voteType  VoteType
  votedById Int
  user      User     @relation(fields: [votedById], references: [id])

  businessProfileCustomCategoryId Int
  businessProfileCustomCategory   BusinessProfileCustomCategory @relation(fields: [businessProfileCustomCategoryId], references: [id])

  @@unique([votedById, businessProfileCustomCategoryId])
}

enum VoteType {
  UP
  DOWN
}
