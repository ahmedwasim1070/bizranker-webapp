// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BusinessProfile {
  id           Int        @id @default(autoincrement())
  name         String     @unique
  pfpUrl       String     @unique
  categoryId   Int
  category     Category   @relation(fields: [categoryId], references: [id])
  city         String
  country      String
  owner        String
  phone        String?
  website      String?
  reviewRating Float?
  reviewAmount Int?
  votes        UserVote[]
}

model Category {
  id       Int               @id @default(autoincrement())
  name     String            @unique
  profiles BusinessProfile[]
}

model UserVote {
  id        Int             @id @default(autoincrement())
  ip        String
  profileId Int
  profile   BusinessProfile @relation(fields: [profileId], references: [id])
  type      VoteType

  @@unique([ip, profileId])
}

enum VoteType {
  UP
  DOWN
}
